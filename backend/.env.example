# OpenAI — generative thesis + forum sentiment (optional locally, recommended for demo)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Supabase — persistent forum comments (optional for local dev, required for production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production CORS — comma-separated Vercel URL(s)
# FRONTEND_URL=https://your-app.vercel.app

# Server
PORT=3001

# Optional live ESG data sources
# ESGENOME_API_URL=
# ESGENOME_API_KEY=
# SGXFIRST_API_URL=
# AI_THESIS_ON_LOAD=true
